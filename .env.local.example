# ═══════════════════════════════════════════════════
# JAKLAY — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# Supabase (supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://jaklay.vercel.app

# Webhook secret (Make.com auth)
WEBHOOK_SECRET=jaklay_webhook_secret_changeme

# Stripe (stripe.com/dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe, then paste Price IDs:
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...
